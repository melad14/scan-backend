NODE_ENV=development
PORT=3000

# MongoDB
MONGODB_URI=mongodb://localhost:27017/scanGo

# JWT Secrets
JWT_ACCESS_SECRET=your_super_secret_access_key_here
JWT_REFRESH_SECRET=your_super_secret_refresh_key_here
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# MinIO Storage (Local Dev mock fallback supported)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_PRESCRIPTIONS=prescriptions
MINIO_BUCKET_REPORTS=reports

# Firebase Cloud Messaging
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvgIBADANBgkqhkiG9w0BAQEFAASCBKgwggSkAgEAAoIBAQC...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com

# SMS Provider API (Mocking supported if left blank or key is mock)
SMS_API_KEY=mock
SMS_SENDER_ID=ScanGo

# Feature Flags
REALTIME_TRACKING_ENABLED=false
WHATSAPP_ENABLED=false
ELECTRONIC_PAYMENTS_ENABLED=false
